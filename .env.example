# Copy this file to `.env` (same folder) and fill in your real values.
# `.env` itself must NEVER be committed, shared, or uploaded anywhere --
# it's already excluded in .gitignore. This file (.env.example) has no
# real secrets in it, so it's safe to share/commit as a template.

# --- Anthropic API ---
# Get this from console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional -- defaults to claude-sonnet-4-6 if omitted
CLAUDE_MODEL=claude-sonnet-4-6

# --- Telegram ---
# Create a bot via @BotFather in Telegram to get this token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Message your bot once, then visit:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# and copy the "chat":{"id": ...} value from the response
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- MT5 ---
# Your broker account number, password, and server name
# (leave MT5_LOGIN/PASSWORD/SERVER blank if the MT5 terminal is already
# logged in and you just want the bot to use that existing session)
MT5_LOGIN=0
MT5_PASSWORD=your_mt5_password_here
MT5_SERVER=YourBroker-Server

# Optional -- path to terminal64.exe if MT5 isn't in its default location.
# Leave blank to auto-detect.
MT5_PATH=
